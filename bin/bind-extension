#!/usr/bin/env bash
# bind-extension: asocia una extension de archivo a una app por defecto (via duti).

APP=$1
EXTENSION=$2

function usage {
    echo "Usage: $0 [app] [extension]"
    echo "Example: MacDown .md"
    exit 1
}

[ -z "$APP" ] && usage
[ -z "$EXTENSION" ] && usage


BUNDLE_ID=$(osascript -e "id of app \"$APP\"")
RETURN_CODE=$?

if [ "$RETURN_CODE" -ne 0 ] || [ -z "$BUNDLE_ID" ]; then
    echo "App $APP not found"
    exit 1
fi

duti -s "$BUNDLE_ID" "$EXTENSION" all
